@model ErrorViewModel
@{
    ViewData["Title"] = "Bir Hata Oluştu";
}

<style>
    .error-page { text-align: center; padding: 5rem 2rem; }
    .error-code { font-size: 6rem; font-weight: 900; background: linear-gradient(135deg,#667eea,#764ba2); -webkit-background-clip: text; -webkit-text-fill-color: transparent; line-height: 1; }
    .error-icon { font-size: 5rem; margin-bottom: 1rem; }
</style>

<div class="error-page">
    <div class="error-icon">⚠️</div>
    <div class="error-code">500</div>
    <h2 class="fw-bold mt-3 mb-2">Bir şeyler ters gitti</h2>
    <p class="text-muted mb-4">Üzgünüz, sunucumuzda bir hata oluştu. Lütfen daha sonra tekrar deneyin.</p>

    @if (Model?.ShowRequestId == true)
    {
        <p class="text-muted small mb-4">Hata kodu: <code>@Model.RequestId</code></p>
    }

    <div class="d-flex gap-3 justify-content-center">
        <a href="javascript:history.back()" class="btn btn-outline-secondary rounded-3">
            <i class="fas fa-arrow-left me-1"></i>Geri Dön
        </a>
        <a href="/" class="btn btn-primary rounded-3">
            <i class="fas fa-home me-1"></i>Ana Sayfa
        </a>
    </div>
</div>
