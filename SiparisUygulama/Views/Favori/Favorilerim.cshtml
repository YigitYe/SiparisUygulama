@model List<SiparisUygulama.Models.Favori>
@{
    ViewData["Title"] = "Favorilerim";
}

<style>
    .favori-card { border: none; border-radius: 14px; box-shadow: 0 2px 12px rgba(0,0,0,0.07); transition: transform 0.2s; }
    .favori-card:hover { transform: translateY(-3px); }
    .restoran-img { width: 100%; height: 120px; object-fit: cover; border-radius: 10px 10px 0 0; }
    .restoran-img-placeholder { width: 100%; height: 120px; background: linear-gradient(135deg,#f1f3f5,#e9ecef); border-radius: 10px 10px 0 0; display: flex; align-items: center; justify-content: center; font-size: 2.5rem; }
</style>

<div class="d-flex align-items-center gap-3 mb-4">
    <a href="/Restoran/Index" class="btn btn-outline-secondary btn-sm rounded-3">
        <i class="fas fa-arrow-left me-1"></i>Geri
    </a>
    <h4 class="fw-bold mb-0">Favorilerim</h4>
    <span class="badge bg-danger ms-1">❤️ @Model.Count</span>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <div >❤️</div>
        <h5 class="">Henüz favori restoranınız yok</h5>
        <p class="text-muted small">Restoran kartlarındaki ❤️ butonuna tıklayarak favori ekleyebilirsiniz.</p>
        <a href="/Restoran/Index" class="btn btn-primary mt-2 rounded-3">Restoranlara Göz At</a>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var f in Model)
        {
            <div class="col-md-4 col-sm-6">
                <div class="favori-card card h-100" style="overflow:hidden;">
                    @if (!string.IsNullOrEmpty(f.Restoran?.GorselUrl))
                    {
                        <img src="@f.Restoran.GorselUrl" class="restoran-img" alt="@f.Restoran.RestaurantName" />
                    }
                    else
                    {
                        <div class="restoran-img-placeholder">🍽️</div>
                    }
                    <div class="card-body p-3">
                        <div class="d-flex justify-content-between align-items-start mb-1">
                            <h6 class="fw-bold mb-0">@f.Restoran?.RestaurantName</h6>
                            @if (!string.IsNullOrEmpty(f.Restoran?.MutfakTuru))
                            {
                                <span class="badge bg-light text-dark" style="font-size:0.72rem;">@f.Restoran.MutfakTuru</span>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(f.Restoran?.Adres))
                        {
                            <p class="text-muted small mb-2" style="font-size:0.78rem;">
                                <i class="fas fa-map-marker-alt me-1"></i>@f.Restoran.Adres
                            </p>
                        }
                        <div class="text-muted small mb-3">
                            <i class="fas fa-heart text-danger me-1"></i>@f.EklenmeTarihi.ToString("dd MMM yyyy") tarihinde eklendi
                        </div>
                        <div class="d-flex gap-2">
                            <a href="/Restoran/Details/@f.RestaurantId" class="btn btn-primary btn-sm flex-grow-1 rounded-3">
                                <i class="fas fa-utensils me-1"></i>Menüye Git
                            </a>
                            <button class="btn btn-outline-danger btn-sm rounded-3"
                                    onclick="favoriKaldir(@f.RestaurantId, this)" title="Favoriden Çıkar">
                                <i class="fas fa-heart-broken"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
<script>
function favoriKaldir(restoranId, btn) {
    fetch('/Favori/Toggle', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'restoranId=' + restoranId
    }).then(() => {
        btn.closest('.col-md-4, .col-sm-6').remove();
    });
}
</script>
}
