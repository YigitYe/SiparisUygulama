@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Giriş Yap — Yemek Sipariş</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.3.0/css/all.min.css" />
    <style>
        :root {
            --orange: #FF6B35;
            --orange-hover: #e85c28;
            --dark: #1a1f2e;
            --dark2: #2d3561;
        }

        * { font-family: 'Inter', sans-serif; box-sizing: border-box; }

        body {
            min-height: 100vh;
            display: flex;
            margin: 0;
            background: #f5f5f5;
        }

        /* ── LEFT PANEL ── */
        .left-panel {
            width: 60%;
            background: linear-gradient(145deg, var(--dark) 0%, var(--dark2) 50%, #3d2b6e 100%);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 3rem;
            color: white;
            position: relative;
            overflow: hidden;
        }

        /* Decorative blobs */
        .left-panel::before {
            content: '';
            position: absolute;
            width: 450px; height: 450px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(255,107,53,0.2) 0%, transparent 70%);
            top: -120px; right: -120px;
        }
        .left-panel::after {
            content: '';
            position: absolute;
            width: 320px; height: 320px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(232,62,140,0.15) 0%, transparent 70%);
            bottom: -80px; left: -80px;
        }

        .left-content { position: relative; z-index: 2; text-align: center; max-width: 440px; }

        .food-collage {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-bottom: 2rem;
            flex-wrap: wrap;
        }
        .food-item {
            width: 70px; height: 70px;
            border-radius: 18px;
            background: rgba(255,255,255,0.1);
            backdrop-filter: blur(8px);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            border: 1px solid rgba(255,255,255,0.12);
            transition: transform 0.3s;
            animation: floatItem 3s ease-in-out infinite;
        }
        .food-item:nth-child(2) { animation-delay: 0.4s; }
        .food-item:nth-child(3) { animation-delay: 0.8s; }
        .food-item:nth-child(4) { animation-delay: 1.2s; }
        .food-item:nth-child(5) { animation-delay: 1.6s; }
        @@keyframes floatItem {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-6px); }
        }

        .brand-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: rgba(255,107,53,0.2);
            border: 1px solid rgba(255,107,53,0.4);
            border-radius: 50px;
            padding: 6px 16px;
            font-size: 0.8rem;
            font-weight: 600;
            color: #ffb899;
            margin-bottom: 1.2rem;
            letter-spacing: 0.04em;
        }

        .brand-title {
            font-size: 2.6rem;
            font-weight: 800;
            line-height: 1.1;
            margin-bottom: 0.8rem;
            background: linear-gradient(135deg, #fff 0%, #ffcfb8 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .brand-sub {
            font-size: 1.05rem;
            opacity: 0.75;
            line-height: 1.5;
            max-width: 340px;
            margin: 0 auto 2.5rem;
        }

        .feature-list {
            list-style: none;
            padding: 0;
            margin: 0;
            text-align: left;
            width: 100%;
        }
        .feature-list li {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 16px;
            border-radius: 12px;
            background: rgba(255,255,255,0.06);
            border: 1px solid rgba(255,255,255,0.08);
            margin-bottom: 8px;
            font-size: 0.88rem;
            opacity: 0.9;
        }
        .feature-list li .feat-icon {
            width: 36px; height: 36px;
            border-radius: 10px;
            background: rgba(255,107,53,0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            font-size: 1rem;
        }

        /* ── RIGHT PANEL ── */
        .right-panel {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 3rem 2.5rem;
            background: white;
        }

        .login-card { width: 100%; max-width: 400px; }

        .login-header { margin-bottom: 2rem; }
        .login-header h4 {
            font-weight: 800;
            color: var(--dark);
            font-size: 1.6rem;
            margin-bottom: 0.3rem;
        }
        .login-header .subtitle { color: #888; font-size: 0.9rem; }

        /* Role pills */
        .role-tabs { display: flex; gap: 8px; margin-bottom: 1.8rem; }
        .role-tab {
            flex: 1;
            padding: 10px 8px;
            border-radius: 12px;
            border: 2px solid #e9ecef;
            background: white;
            cursor: pointer;
            text-align: center;
            font-size: 0.8rem;
            font-weight: 600;
            color: #888;
            transition: all 0.2s;
        }
        .role-tab:hover { border-color: var(--orange); color: var(--orange); background: #fff8f5; }
        .role-tab.active {
            border-color: var(--orange);
            background: var(--orange);
            color: white;
            box-shadow: 0 4px 14px rgba(255,107,53,0.3);
        }
        .role-tab i { display: block; font-size: 1.1rem; margin-bottom: 4px; }

        /* Inputs */
        .form-label { font-weight: 600; font-size: 0.84rem; color: #444; margin-bottom: 6px; }
        .input-wrapper { position: relative; }
        .input-wrapper .input-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #bbb;
            font-size: 0.9rem;
            z-index: 2;
        }
        .form-control {
            padding: 12px 14px 12px 42px;
            border-radius: 12px;
            border: 2px solid #e9ecef;
            font-size: 0.9rem;
            transition: border-color 0.2s, box-shadow 0.2s;
            background: #fafafa;
        }
        .form-control:focus {
            border-color: var(--orange);
            box-shadow: 0 0 0 3px rgba(255,107,53,0.12);
            background: #fff;
        }

        /* Login button */
        .btn-login {
            background: linear-gradient(135deg, var(--orange) 0%, #e83e8c 100%);
            border: none;
            border-radius: 12px;
            padding: 13px;
            font-weight: 700;
            font-size: 0.95rem;
            letter-spacing: 0.3px;
            color: white;
            transition: opacity 0.2s, transform 0.1s, box-shadow 0.2s;
            box-shadow: 0 4px 16px rgba(255,107,53,0.3);
        }
        .btn-login:hover {
            opacity: 0.92;
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(255,107,53,0.4);
            color: white;
        }
        .btn-login:active { transform: translateY(0); }

        /* Divider */
        .divider {
            display: flex;
            align-items: center;
            gap: 12px;
            color: #bbb;
            font-size: 0.8rem;
            margin: 1.2rem 0;
        }
        .divider::before, .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #e9ecef;
        }

        /* Register button */
        .btn-register {
            border: 2px solid #e9ecef;
            border-radius: 12px;
            color: #555;
            font-weight: 600;
            font-size: 0.88rem;
            transition: border-color 0.2s, color 0.2s, background 0.2s;
            padding: 10px;
        }
        .btn-register:hover { border-color: var(--orange); color: var(--orange); background: #fff8f5; }

        /* Register card inputs (no icon padding) */
        #kayitCard .form-control { padding: 10px 14px; }

        /* Error alert */
        .alert-danger { border-radius: 12px; font-size: 0.87rem; border: none; background: #fff5f5; color: #c0392b; }

        @@media (max-width: 768px) {
            .left-panel { display: none; }
            .right-panel { padding: 2rem 1.5rem; }
        }
        @@media (max-width: 480px) {
            .right-panel { padding: 1.5rem 1.2rem; }
        }
    </style>
</head>
<body>
    <!-- Sol Panel -->
    <div class="left-panel">
        <div class="left-content">
            <div class="brand-badge">
                <i class="fas fa-bolt"></i> Yapay Zeka Destekli Platform
            </div>

            <div class="food-collage">
                <div class="food-item">🍕</div>
                <div class="food-item">🍔</div>
                <div class="food-item">🍜</div>
                <div class="food-item">🌮</div>
                <div class="food-item">🍱</div>
            </div>

            <div class="brand-title">Yemek Sipariş</div>
            <p class="brand-sub">En lezzetli restoranlar, kapınıza kadar</p>

            <ul class="feature-list">
                <li>
                    <div class="feat-icon"><i class="fas fa-robot" style="color:#FF6B35;"></i></div>
                    <div>
                        <div style="font-weight:600;">AI Destekli Öneriler</div>
                        <div style="font-size:0.78rem;opacity:0.65;margin-top:1px;">Zevkinize göre kişiselleştirilmiş menü</div>
                    </div>
                </li>
                <li>
                    <div class="feat-icon"><i class="fas fa-route" style="color:#4ecdc4;"></i></div>
                    <div>
                        <div style="font-weight:600;">Akıllı Rota Optimizasyonu</div>
                        <div style="font-size:0.78rem;opacity:0.65;margin-top:1px;">TSP algoritması ile en hızlı teslimat</div>
                    </div>
                </li>
                <li>
                    <div class="feat-icon"><i class="fas fa-star" style="color:#f1c40f;"></i></div>
                    <div>
                        <div style="font-weight:600;">NLP Duygu Analizi</div>
                        <div style="font-size:0.78rem;opacity:0.65;margin-top:1px;">Yorumları akıllıca analiz eden sistem</div>
                    </div>
                </li>
                <li>
                    <div class="feat-icon"><i class="fas fa-bolt" style="color:#a29bfe;"></i></div>
                    <div>
                        <div style="font-weight:600;">Hızlı & Güvenli Teslimat</div>
                        <div style="font-size:0.78rem;opacity:0.65;margin-top:1px;">Gerçek zamanlı takip ve SHA-256 güvenlik</div>
                    </div>
                </li>
            </ul>
        </div>
    </div>

    <!-- Sağ Panel -->
    <div class="right-panel">
        <div class="login-card">
            <div class="login-header">
                <h4>Hoş Geldiniz 👋</h4>
                <p class="subtitle">Hesabınıza giriş yapın</p>
            </div>

            @if (ViewBag.Hata != null)
            {
                <div class="alert alert-danger py-2 px-3 mb-3">
                    <i class="fas fa-exclamation-circle me-1"></i>@ViewBag.Hata
                </div>
            }

            <!-- Rol Seçimi -->
            <div class="role-tabs">
                <div class="role-tab active" onclick="setRole('Musteri', this)">
                    <i class="fas fa-user"></i>Müşteri
                </div>
                <div class="role-tab" onclick="setRole('Yonetici', this)">
                    <i class="fas fa-user-tie"></i>Yönetici
                </div>
                <div class="role-tab" onclick="setRole('Personel', this)">
                    <i class="fas fa-motorcycle"></i>Personel
                </div>
            </div>

            <!-- Giriş Formu -->
            <form method="post" id="loginForm">
                <input type="hidden" id="girisTipi" name="girisTipi" value="Musteri" />

                <div class="mb-3">
                    <label class="form-label">Kullanıcı Adı</label>
                    <div class="input-wrapper">
                        <i class="input-icon fas fa-user"></i>
                        <input type="text" name="kullaniciAdi" class="form-control" placeholder="Kullanıcı adınız" required />
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label">Şifre</label>
                    <div class="input-wrapper">
                        <i class="input-icon fas fa-lock"></i>
                        <input type="password" name="sifre" class="form-control" placeholder="••••••••" required />
                    </div>
                </div>

                <button type="submit" class="btn btn-login w-100 mb-1">
                    <i class="fas fa-sign-in-alt me-2"></i>Giriş Yap
                </button>
            </form>

            <!-- Kayıt Ol (sadece müşteri) -->
            <div id="kayitSection">
                <div class="divider">veya</div>
                <button class="btn btn-register w-100"
                        onclick="document.getElementById('kayitCard').classList.toggle('d-none')">
                    <i class="fas fa-user-plus me-2"></i>Hesap Oluştur
                </button>
            </div>

            <!-- Kayıt Formu -->
            <div id="kayitCard" class="d-none mt-3">
                <hr style="border-color:#f0f0f0;" />
                <h6 class="fw-bold mb-3" style="color:var(--dark);">Yeni Müşteri Kaydı</h6>
                <form id="kayitForm">
                    <div class="row g-2 mb-2">
                        <div class="col-6">
                            <input type="text" name="KullaniciAdi" class="form-control" placeholder="Kullanıcı Adı" required />
                        </div>
                        <div class="col-6">
                            <input type="password" name="Sifre" class="form-control" placeholder="Şifre" required />
                        </div>
                    </div>
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <input type="email" name="Email" class="form-control" placeholder="Email" required />
                        </div>
                        <div class="col-6">
                            <input type="text" name="Telefon" class="form-control" placeholder="Telefon" />
                        </div>
                    </div>
                    <button type="submit" class="btn btn-success w-100 rounded-3">
                        <i class="fas fa-check me-1"></i>Kayıt Ol
                    </button>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        function setRole(rol, el) {
            document.getElementById('girisTipi').value = rol;
            document.querySelectorAll('.role-tab').forEach(t => t.classList.remove('active'));
            el.classList.add('active');
            document.getElementById('kayitSection').style.display = rol === 'Musteri' ? 'block' : 'none';
        }

        $('#kayitForm').submit(function (e) {
            e.preventDefault();
            $.ajax({
                url: '/Giris/KullaniciKayit', type: 'POST', data: $(this).serialize(),
                success: function () {
                    alert('Kayıt başarılı! Giriş yapabilirsiniz.');
                    document.getElementById('kayitCard').classList.add('d-none');
                },
                error: function (xhr) { alert('Kayıt başarısız: ' + xhr.responseText); }
            });
        });
    </script>
</body>
</html>
