@model List<SiparisUygulama.Models.Sipari>
@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Gelen Siparişler";
}

<style>
    .siparis-card { border: none; border-radius: 14px; box-shadow: 0 2px 12px rgba(0,0,0,0.07); margin-bottom: 1rem; }
    .durum-select { border-radius: 8px; border: 1.5px solid #e9ecef; font-size: 0.85rem; padding: 5px 10px; cursor: pointer; }
    .badge-beklemede { background: #e0e7ff; color: #3730a3; }
    .badge-hazirlaniyor { background: #fef3c7; color: #92400e; }
    .badge-hazir { background: #d1fae5; color: #065f46; }
    .badge-teslim { background: #f3f4f6; color: #374151; }
    .menu-pill { display: inline-block; background: #f1f3f5; border-radius: 20px; padding: 2px 10px; font-size: 0.78rem; margin: 2px; }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">Gelen Siparişler</h4>
        <span class="text-muted small">@Model.Count toplam sipariş</span>
    </div>
    <div class="d-flex gap-2">
        <span class="badge rounded-pill bg-warning text-dark">
            @Model.Count(s => s.OrderStatus == "Beklemede") Beklemede
        </span>
        <span class="badge rounded-pill bg-info text-dark">
            @Model.Count(s => s.OrderStatus == "Hazırlanıyor") Hazırlanıyor
        </span>
        <span class="badge rounded-pill bg-success">
            @Model.Count(s => s.OrderStatus == "Hazır") Hazır
        </span>
    </div>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <div >📋</div>
        <h5 class="">Henüz sipariş yok</h5>
    </div>
}
else
{
    @foreach (var s in Model)
    {
        var badgeClass = s.OrderStatus switch {
            "Hazırlanıyor" => "badge-hazirlaniyor",
            "Hazır" => "badge-hazir",
            "Teslim Edildi" => "badge-teslim",
            _ => "badge-beklemede"
        };

        <div class="siparis-card card">
            <div class="card-body p-4">
                <div class="row align-items-center g-3">
                    <div class="col-md-1">
                        <div class="text-muted small">Sipariş</div>
                        <div class="fw-bold">#@s.OrderId</div>
                    </div>
                    <div class="col-md-2">
                        <div class="text-muted small">Müşteri</div>
                        <div class="fw-semibold small">@s.Kullanici?.KullaniciAdi</div>
                    </div>
                    <div class="col-md-3">
                        <div class="text-muted small mb-1">Ürünler</div>
                        <div>
                            @foreach (var item in s.SiparisDetays)
                            {
                                <span class="menu-pill">@item.MenuItem?.ItemName</span>
                            }
                        </div>
                    </div>
                    <div class="col-md-2">
                        <div class="text-muted small">Tutar</div>
                        <div class="fw-bold text-success">₺@s.TotalAmount</div>
                    </div>
                    <div class="col-md-2">
                        <div class="text-muted small">Tarih</div>
                        <div class="small">@s.OrderDate.ToString("dd MMM, HH:mm")</div>
                    </div>
                    <div class="col-md-2">
                        @if (s.OrderStatus is "Yolda" or "Teslim Edildi")
                        {
                            var renk = s.OrderStatus == "Yolda" ? "bg-warning text-dark" : "bg-success text-white";
                            var ikon = s.OrderStatus == "Yolda" ? "🛵" : "📦";
                            <span class="badge @renk px-3 py-2 rounded-pill">@ikon @s.OrderStatus</span>
                        }
                        else
                        {
                            <form asp-action="DurumGuncelle" method="post" class="d-flex gap-2 align-items-center">
                                <input type="hidden" name="orderId" value="@s.OrderId" />
                                <select name="yeniDurum" class="durum-select flex-grow-1" data-current="@s.OrderStatus" onchange="this.form.submit()">
                                    <option value="Beklemede">⏳ Beklemede</option>
                                    <option value="Hazırlanıyor">👨‍🍳 Hazırlanıyor</option>
                                    <option value="Hazır">✅ Hazır - Kurye Bekliyor</option>
                                </select>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
}

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
    document.querySelectorAll('select[data-current]').forEach(sel => {
        sel.value = sel.dataset.current;
    });

    // SignalR: yeni sipariş veya durum değişikliğini dinle
    const conn = new signalR.HubConnectionBuilder().withUrl('/siparisHub').withAutomaticReconnect().build();

    conn.on('SiparisDurumGuncellendi', function(orderId, yeniDurum) {
        // Toast bildirimi göster
        const toast = document.createElement('div');
        toast.className = 'position-fixed top-0 end-0 m-3 alert alert-info shadow rounded-3 py-2 px-3';
        toast.style.zIndex = '9999';
        toast.innerHTML = '<i class="fas fa-bell me-1"></i>Sipariş #' + orderId + ': <strong>' + yeniDurum + '</strong>';
        document.body.appendChild(toast);
        setTimeout(() => { toast.remove(); location.reload(); }, 2000);
    });

    conn.start().catch(err => console.warn('SignalR bağlanamadı:', err));
</script>
}
